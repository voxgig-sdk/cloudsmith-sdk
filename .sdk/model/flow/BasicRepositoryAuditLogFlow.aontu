# BasicRepositoryAuditLogFlow

main: kit: flow: BasicRepositoryAuditLogFlow:
{
  entity: "repository_audit_log",
  kind: "basic",
  name: "BasicRepositoryAuditLogFlow",
  step: [
    {
      match: {
        owner: "owner01",
        repo: "repo01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "repository_audit_log_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicRepositoryAuditLogFlow"
}